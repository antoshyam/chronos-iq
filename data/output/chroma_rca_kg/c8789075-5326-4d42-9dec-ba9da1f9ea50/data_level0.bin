_infrastructure_issue\",\"target_id\":\"log_RCA_f179cca2\"},{\"id\":\"rel_status_commander_extracted_from_log\",\"name\":\"extracted_from\",\"description\":\"Commander status extracted from RCA source log.\",\"source_id\":\"status_no_commander_failure_evidence\",\"target_id\":\"log_RCA_f179cca2\"},{\"id\":\"rel_status_incident_extracted_from_log\",\"name\":\"extracted_from\",\"description\":\"Incident status extracted from RCA source log.\",\"source_id\":\"status_no_formal_incident\",\"target_id\":\"log_RCA_f179cca2\"},{\"id\":\"rel_rootcause_extracted_from_log\",\"name\":\"extracted_from\",\"description\":\"Root cause extracted from RCA source log.\",\"source_id\":\"root_cause_farm_wide_Kerberos_ticket_expiry_QCDFS_auth_failure\",\"target_id\":\"log_RCA_f179cca2\"},{\"id\":\"rel_gap_no_dd_extracted_from_log\",\"name\":\"extracted_from\",\"description\":\"Data gap extracted from RCA source log.\",\"source_id\":\"gap_no_datadog_telemetry_crm_ubuntulv118\",\"target_id\":\"log_RCA_f179cca2\"},{\"id\":\"rel_gap_no_direct_extracted_from_log\",\"name\":\"extracted_from\",\"description\":\"Data gap extracted from RCA source log.\",\"source_id\":\"gap_no_direct_kerberos_expiry_on_crm_ubuntulv118\",\"target_id\":\"log_RCA_f179cca2\"},{\"id\":\"rel_gap_cb_logs_extracted_from_log\",\"name\":\"extracted_from\",\"description\":\"Data gap extracted from RCA source log.\",\"source_id\":\"gap_cloudbees_step_logs_unavailable\",\"target_id\":\"log_RCA_f179cca2\"},{\"id\":\"rel_gap_commander_extracted_from_log\",\"name\":\"extracted_from\",\"description\":\"Data gap extracted from RCA source log.\",\"source_id\":\"gap_commander_host_not_identified\",\"target_id\":\"log_RCA_f179cca2\"},{\"id\":\"rel_gap_kerberos_mode_extracted_from_log\",\"name\":\"extracted_from\",\"description\":\"Data gap extracted from RCA source log.\",\"source_id\":\"gap_exact_kerberos_failure_mode_unresolved\",\"target_id\":\"log_RCA_f179cca2\"},{\"id\":\"rel_gap_splunk_extracted_from_log\",\"name\":\"extracted_